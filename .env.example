# Google Search Console OAuth credentials (downloaded from Google Cloud Console)
# See docs/gsc-setup.md for the full setup guide
GOOGLE_CREDENTIALS_PATH=/path/to/credentials.json

# Optional: override the token storage location (default: ~/.creator-seo-mcp/token.json)
# CREATOR_SEO_TOKEN_PATH=/path/to/token.json

# Revenue configuration
# Site-wide display ad RPM in USD (ask your ad network dashboard)
CREATOR_SEO_SITE_RPM=15.0

# Per-category affiliate commission multipliers (JSON)
# Keys are URL path prefixes; multipliers are applied on top of the RPM baseline
# Example: affiliate posts earn 2x because commissions are higher than display RPM
# CREATOR_SEO_AFFILIATE_CATEGORIES={"gaming-deals": 2.0, "hardware": 1.8}

# Optional: custom CTR curve by position (JSON, keys 1-15)
# Defaults to Advanced Web Ranking industry averages if unset
# CREATOR_SEO_CTR_CURVE={"1": 0.279, "2": 0.153, "3": 0.105}

# WordPress integration (Phase 3, optional)
# WORDPRESS_SITE_URL=https://yoursite.com
# WORDPRESS_USERNAME=your-wp-username
# WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
# WORDPRESS_DRAFT_PUSH_ENABLED=false
